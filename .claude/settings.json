{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[ADS-B Secure] File modified: check security implications and update docs/vault/ if significant change was made.'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[ADS-B Secure] Running shell command — ensure no secrets are echoed and no destructive operations on device-rpi/ without reading first.'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python3 -m pytest*)",
      "Bash(bandit*)",
      "Bash(pip-audit*)",
      "Bash(pip install*)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)"
    ]
  }
}
